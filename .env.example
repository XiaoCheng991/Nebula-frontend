# ============================================
# NebulaHub - 环境变量配置
# ============================================

# ============================================
# API 模式配置
# ============================================
# 可选值：'java-backend' | 'supabase'
# 切换模式只需修改这里，无需改代码
NEXT_PUBLIC_API_MODE=supabase

# ============================================
# Java Backend 配置
# ============================================
# NEXT_PUBLIC_API_URL=http://localhost:8080

# ============================================
# Supabase 配置（切换到 supabase 模式时取消注释并填写）
# ============================================
NEXT_PUBLIC_SUPABASE_URL=<YOUR_SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# ============================================
# GitHub OAuth 配置
# ============================================
NEXT_PUBLIC_GITHUB_CLIENT_ID=<YOUR_GITHUB_CLIENT_ID>

# ============================================
# MinIO 对象存储配置
# ============================================
MINIO_ENDPOINT=<YOUR_MINIO_ENDPOINT>
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=<YOUR_MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<YOUR_MINIO_SECRET_KEY>
MINIO_BUCKET=user-uploads
MINIO_PUBLIC_URL=<YOUR_MINIO_PUBLIC_URL>

# ============================================
# AI 服务配置（保留用于 AI 聊天功能）
# ============================================
MINIMAX_API_KEY=<YOUR_MINIMAX_API_KEY>
MINIMAX_API_URL=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_MODEL=abab6.5s-chat

# ============================================
# 应用配置
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NebulaHub

# ============================================
# 开发环境配置
# ============================================
NODE_ENV=development
DEBUG=true
